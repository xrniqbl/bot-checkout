TELEGRAM_BOT_TOKEN=isi_token_dari_BotFather
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TWOCAPTCHA_API_KEY=
HEADLESS=false
SLOW_MO_MS=50
DEFAULT_PROXY=

# (Opsional, SANGAT disarankan utk Shopee) pakai profil Chrome asli kamu.
# Cari di: chrome://version -> "Profile Path" -> ambil folder INDUK "User Data".
# Contoh Windows: C:/Users/Iqbal/AppData/Local/Google/Chrome/User Data
# Tutup Chrome dulu sebelum jalankan bot (profil terkunci kalau Chrome terbuka).
CHROME_USER_DATA_DIR=
SESSION_ENCRYPTION_KEY=
DATABASE_URL=sqlite:///database/bot.db
# === MODE ADU-TEKNIS (anti-deteksi terkuat) ===
# 1. Tutup semua Chrome. Jalankan Chrome khusus bot:
#    "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222 --user-data-dir="C:/chrome-bot"
# 2. Login Shopee manual di Chrome itu (sekali saja).
# 3. Set baris ini, lalu jalankan: python main.py
CHROME_CDP_URL=http://localhost:9222
